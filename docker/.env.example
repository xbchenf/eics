# ============================================================================
# EICS 环境变量模板 — 复制为 .env 并修改为实际值
# cp .env.example .env
# ============================================================================

# ---------- MySQL ----------
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=eics_main
MYSQL_USER=eics
MYSQL_PASSWORD=change_me_user_password

# ---------- Redis ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password

# ---------- Milvus ----------
MILVUS_ACCESS_KEY=change_me_milvus_key
MILVUS_SECRET_KEY=change_me_milvus_secret

# ---------- MinIO ----------
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=change_me_minio_password

# ---------- 阿里百炼 LLM ----------
DASHSCOPE_API_KEY=sk-your-dashscope-api-key
LLM_MODEL=qwen-max
EMBEDDING_MODEL=text-embedding-v4

# ---------- JWT ----------
JWT_SECRET=change_me_to_a_random_string_at_least_32_chars
JWT_EXPIRE_HOURS=24
